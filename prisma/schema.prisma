generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  encryptedApiKey String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]
  metrics  PipelineMetric[]
  feedback ProjectFeedback[]
  specCaches SpecCache[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  created_at        Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs    PipelineRun[]
  files   ProjectFile[]
  metrics PipelineMetric[]
  feedback ProjectFeedback[]
}

model PipelineRun {
  id                String    @id @default(cuid())
  projectId         String
  type              String
  status            String    @default("running")
  currentStageIndex Int       @default(0)
  userInput         String    @db.Text
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  totalDurationMs   Int?

  // DAG execution fields
  executionPlan     Json?          // serialized ExecutionPlan { nodes, edges }
  planApproved      Boolean        @default(false)
  outputPath        String?        // disk path for generated project files
  executionMode     String         @default("linear") // 'linear' | 'dag'

  // Automation
  autoApprove       Boolean        @default(false)  // skip human gates, auto-approve all stages

  // Traceability
  traceId           String?        @unique

  project            Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stages             PipelineStage[]
  files              ProjectFile[]
  metrics            PipelineMetric[]
  traceEvents        TraceEvent[]
  agentVotes         AgentVote[]
  confidenceScores   ConfidenceScore[]
  completenessChecks CompletenessCheck[]
}

model PipelineStage {
  id              String    @id @default(cuid())
  runId           String
  stageIndex      Int
  skillName       String
  displayName     String
  status          String    @default("pending")
  artifactContent String?   @db.Text
  streamContent   String?   @db.Text
  userFeedback    String?   @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  approvedAt      DateTime?

  // Token usage tracking
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  modelUsed       String?                  // e.g. 'claude-sonnet-4-20250514' or 'llama3.1:8b'
  backend         String?                  // 'anthropic' or 'ollama'
  costUsd         Float     @default(0)    // estimated cost in USD

  // DAG execution fields
  dependsOn       String[]  @default([])   // IDs of stages this node depends on
  nodeType        String    @default("skill") // 'agent' | 'skill' | 'verify' | 'gate'
  parallelGroup   String?                  // group ID for concurrent execution
  gateType        String?                  // 'plan_approval' | 'phase_review' | 'final_review'
  retryCount      Int       @default(0)
  maxRetries      Int       @default(2)
  outputDir       String?                  // disk path for file output from this node
  phaseIndex      Int?                     // which phase this node belongs to
  nodeId          String?                  // DAG node ID (stable across retries)

  run              PipelineRun       @relation(fields: [runId], references: [id], onDelete: Cascade)
  files            ProjectFile[]
  agentVotes       AgentVote[]
  confidenceScores ConfidenceScore[]
}

model ProjectFile {
  id             String   @id @default(cuid())
  projectId      String
  runId          String?
  filePath       String
  content        String   @db.Text
  language       String   @default("plaintext")
  createdByStage String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run     PipelineRun?   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stage   PipelineStage? @relation(fields: [createdByStage], references: [id])

  @@unique([projectId, filePath])
}

model PipelineMetric {
  id                String   @id @default(cuid())
  runId             String
  projectId         String
  userId            String
  pipelineType      String
  totalDurationMs   Int
  stageCount        Int
  approvedFirstPass Int
  rejectionCount    Int
  outcome           String
  stageDurations    Json     @default("{}")
  totalInputTokens  Int      @default(0)
  totalOutputTokens Int      @default(0)
  totalCostUsd      Float    @default(0)
  stageTokens       Json     @default("{}")  // per-stage token breakdown
  createdAt         DateTime @default(now())

  run     PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TraceEvent {
  id           String   @id @default(cuid())
  runId        String
  traceId      String
  spanId       String
  parentSpanId String?
  eventType    String   // stage_start | stage_complete | agent_spawn | agent_vote | decision_made | error | retry | gate_approved | gate_rejected
  source       String   // dag-executor | agent-coordinator | decision-agent | triage-agent | trace-logger
  message      String   @db.Text
  metadata     Json     @default("{}")
  durationMs   Int?
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float?
  timestamp    DateTime @default(now())

  run PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, timestamp])
  @@index([traceId])
  @@index([spanId])
}

model AgentVote {
  id           String   @id @default(cuid())
  runId        String
  stageId      String
  spanId       String
  agentRole    String   // architecture | code_quality | security | performance | ux
  votedOption  String
  confidence   Float
  reasoning    String   @db.Text
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  costUsd      Float    @default(0)
  durationMs   Int?
  status       String   @default("pending") // pending | completed | failed
  createdAt    DateTime @default(now())

  run   PipelineRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stage PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
}

model LearningEntry {
  id              String   @id @default(cuid())
  pattern         String   @db.Text    // "phase-builder produced phase with missing acceptance criteria"
  sourceAgent     String               // agent that detected the issue
  targetAgent     String               // agent that caused the issue
  rejectionCount  Int      @default(1)
  firstSeen       DateTime @default(now())
  lastSeen        DateTime @default(now())
  resolution      String?  @db.Text    // how it was resolved
  status          String   @default("active") // active | resolved
  runId           String?              // which run triggered this
  stageId         String?              // which stage triggered this
  metadata        Json     @default("{}")

  @@index([targetAgent, status])
  @@index([pattern])
}

model ConfidenceScore {
  id              String   @id @default(cuid())
  runId           String
  stageId         String
  promptHash      String               // SHA-256 of the prompt content
  score           Float                 // 0.0 - 1.0
  passed          Boolean              // score >= 0.8
  reasoning       String   @db.Text
  checks          Json     @default("[]") // array of { name, pass, detail }
  inputTokens     Int      @default(0)
  outputTokens    Int      @default(0)
  costUsd         Float    @default(0)
  durationMs      Int?
  attempt         Int      @default(1)  // which attempt (1st, 2nd after rejection)
  createdAt       DateTime @default(now())

  run   PipelineRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stage PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([stageId])
}

model CompletenessCheck {
  id              String   @id @default(cuid())
  runId           String
  phaseIndex      Int
  totalCriteria   Int
  passedCriteria  Int
  score           Float                // passedCriteria / totalCriteria
  passed          Boolean              // score >= 1.0
  failures        Json     @default("[]") // array of { criterion, reason }
  filesChecked    Int      @default(0)
  importsResolved Boolean  @default(false)
  appLaunchable   Boolean  @default(false)
  durationMs      Int?
  createdAt       DateTime @default(now())

  run PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, phaseIndex])
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique    // e.g. 'prd-architect', 'phase-executor'
  prompt      String   @db.Text   // the full skill prompt
  version     Int      @default(1)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

model ProjectFeedback {
  id          String   @id @default(cuid())
  projectId   String
  userId      String
  runId       String?
  rating      Int               // 1 = thumbs down, 2 = thumbs up
  comment     String?  @db.Text
  workedOutOfBox Boolean @default(false)
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
}

model SpecCache {
  id             String   @id @default(cuid())
  userId         String
  inputHash      String            // SHA-256 of normalized userInput
  pipelineType   String            // 'build', 'diagnostic', etc.
  executionPlan  Json              // cached ExecutionPlan
  hitCount       Int      @default(0)
  createdAt      DateTime @default(now())
  expiresAt      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, inputHash])
  @@index([inputHash])
}
