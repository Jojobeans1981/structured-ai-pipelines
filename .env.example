# ──────────────────────────────────────────────
# Gauntlet Forge — Environment Variables
# ──────────────────────────────────────────────

# ── Auth (GitLab OAuth — existing) ──
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://labs.gauntletai.com
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ── Database ──
DATABASE_URL=postgresql://forge:forge_dev@localhost:5433/forge
POSTGRES_PASSWORD=forge_dev

# ── Encryption ──
ENCRYPTION_KEY=

# ── LLM API Keys ──
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Google OAuth2 (Gateway) ──
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Gateway ──
JWT_SECRET_KEY=
JWT_EXPIRY_HOURS=24
GATEWAY_PUBLIC_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ── Rate Limiting ──
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
