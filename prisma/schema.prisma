generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  image           String?
  encryptedApiKey String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  projects Project[]
  metrics  PipelineMetric[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  created_at        Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   @default("")
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs    PipelineRun[]
  files   ProjectFile[]
  metrics PipelineMetric[]
}

model PipelineRun {
  id                String    @id @default(cuid())
  projectId         String
  type              String
  status            String    @default("running")
  currentStageIndex Int       @default(0)
  userInput         String    @db.Text
  startedAt         DateTime  @default(now())
  completedAt       DateTime?
  totalDurationMs   Int?

  // DAG execution fields
  executionPlan     Json?          // serialized ExecutionPlan { nodes, edges }
  planApproved      Boolean        @default(false)
  outputPath        String?        // disk path for generated project files
  executionMode     String         @default("linear") // 'linear' | 'dag'

  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stages  PipelineStage[]
  files   ProjectFile[]
  metrics PipelineMetric[]
}

model PipelineStage {
  id              String    @id @default(cuid())
  runId           String
  stageIndex      Int
  skillName       String
  displayName     String
  status          String    @default("pending")
  artifactContent String?   @db.Text
  streamContent   String?   @db.Text
  userFeedback    String?   @db.Text
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  approvedAt      DateTime?

  // Token usage tracking
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  modelUsed       String?                  // e.g. 'claude-sonnet-4-20250514' or 'llama3.1:8b'
  backend         String?                  // 'anthropic' or 'ollama'
  costUsd         Float     @default(0)    // estimated cost in USD

  // DAG execution fields
  dependsOn       String[]  @default([])   // IDs of stages this node depends on
  nodeType        String    @default("skill") // 'agent' | 'skill' | 'verify' | 'gate'
  parallelGroup   String?                  // group ID for concurrent execution
  gateType        String?                  // 'plan_approval' | 'phase_review' | 'final_review'
  retryCount      Int       @default(0)
  maxRetries      Int       @default(2)
  outputDir       String?                  // disk path for file output from this node
  phaseIndex      Int?                     // which phase this node belongs to
  nodeId          String?                  // DAG node ID (stable across retries)

  run   PipelineRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  files ProjectFile[]
}

model ProjectFile {
  id             String   @id @default(cuid())
  projectId      String
  runId          String
  filePath       String
  content        String   @db.Text
  language       String   @default("plaintext")
  createdByStage String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run     PipelineRun   @relation(fields: [runId], references: [id], onDelete: Cascade)
  stage   PipelineStage @relation(fields: [createdByStage], references: [id])

  @@unique([projectId, filePath])
}

model PipelineMetric {
  id                String   @id @default(cuid())
  runId             String
  projectId         String
  userId            String
  pipelineType      String
  totalDurationMs   Int
  stageCount        Int
  approvedFirstPass Int
  rejectionCount    Int
  outcome           String
  stageDurations    Json     @default("{}")
  totalInputTokens  Int      @default(0)
  totalOutputTokens Int      @default(0)
  totalCostUsd      Float    @default(0)
  stageTokens       Json     @default("{}")  // per-stage token breakdown
  createdAt         DateTime @default(now())

  run     PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}
